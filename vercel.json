{
  "version": 2,
  "crons": [
    {
      "path": "/api/jobs/abandoned-carts",
      "schedule": "0 * * * *"
    }
  ],
  "builds": [
    {
      "src": "server_gvf.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "data/**",
          "models/**",
          "routes/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "server_gvf.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server_gvf.js"
    },
    {
      "src": "/products/(.*)",
      "dest": "server_gvf.js"
    },
    {
      "src": "/robots.txt",
      "dest": "server_gvf.js"
    },
    {
      "src": "/sitemap.xml",
      "dest": "server_gvf.js"
    },
    {
      "src": "/BingSiteAuth.xml",
      "dest": "server_gvf.js"
    },
    {
      "src": "/[^/]+\\.txt",
      "dest": "server_gvf.js"
    },
    {
      "src": "/admin",
      "dest": "server_gvf.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "server_gvf.js"
    }
  ]
}
