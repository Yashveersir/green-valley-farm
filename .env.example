# ═══════════════════════════════════════════════════
# Green Valley Poultry Farm — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.
# ═══════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────
# Your MongoDB Atlas connection string
MONGODB_URI=

# ── JWT Auth ─────────────────────────────────────────
# REQUIRED in production. Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Admin Credentials ────────────────────────────────
# Passwords for the two seeded admin accounts.
# These are bcrypt-hashed automatically at startup.
# Set the plain-text passwords here; they live ONLY in .env, never in source code.
ADMIN1_PASSWORD=
ADMIN2_PASSWORD=

# ── SMTP (Email) ─────────────────────────────────────
# Brevo (formerly Sendinblue) or any SMTP provider
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Google OAuth ─────────────────────────────────────
# From Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=

# ── Razorpay ─────────────────────────────────────────
# KEY_ID is publishable (safe to expose in frontend via /api/auth/config)
# KEY_SECRET is private — never expose this to the client
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins in production
ALLOWED_ORIGINS=https://www.green-valley-farm.online,https://green-valley-farm.online

# ── Cron Job Protection ───────────────────────────────
# Secret token required to trigger the abandoned-cart cron job
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Abandoned Cart Settings ───────────────────────────
ABANDONED_CART_HOURS=4
ABANDONED_CART_COUPON_PERCENT=5
ABANDONED_CART_COUPON_DAYS=3

# ── SEO & Deployment ─────────────────────────────────
SITE_URL=https://www.green-valley-farm.online
NODE_ENV=production
PORT=3000
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
BING_XML_VERIFICATION=
INDEXNOW_KEY=
